proxmox_node_name = "norman"

network_bridge  = "vmbr0"
network_gateway = "192.168.1.1"
network_cidr    = 24

search_domain = "lab.adre.me"
dns_servers   = ["192.168.1.1", "1.1.1.1"]

lxc_storage = "local-lvm"

# Consolidated NixOS VM. Build or import a NixOS cloud-init template first,
# then enable this while the old AdGuard LXC remains active.
enable_core_vm         = false
core_vm_template_vm_id = 9000
core_vm_id             = 120
core_vm_ip             = "192.168.1.220" # temporary; cut over to 192.168.1.210 later
core_vm_storage        = "local-lvm"
core_vm_disk_gb        = 96
core_vm_cores          = 4
core_vm_memory_mb      = 8192

service_ips = {
  adguard_lxc     = "192.168.1.210"
  edge_lxc        = "192.168.1.211"
  monitoring_lxc  = "192.168.1.212"
  authelia_lxc    = "192.168.1.213"
  lldap_lxc       = "192.168.1.214"
  jellyfin_lxc    = "192.168.1.230"
  arr_lxc         = "192.168.1.232"
  qbittorrent_lxc = "192.168.1.233"
}

service_vmids = {
  lldap_lxc       = 100
  jellyfin_lxc    = 101
  adguard_lxc     = 102
  edge_lxc        = 103
  arr_lxc         = 104
  monitoring_lxc  = 105
  authelia_lxc    = 106
  qbittorrent_lxc = 107
}

# NixOS LXC template — downloaded from Hydra if manage_lxc_template = true
manage_lxc_template        = true
lxc_template_datastore_id  = "local"
lxc_template_file_name     = "nixos-lxc-homelab.tar.xz"
lxc_template_file_id       = "local:vztmpl/nixos-lxc-homelab.tar.xz"
lxc_template_url           = "https://hydra.nixos.org/job/nixos/release-25.11/nixos.proxmoxLXC.x86_64-linux/latest/download-by-type/file/system-tarball"

# Resource defaults live in variables.tf. Override lxc_resources here only when
# the Proxmox host has a different memory budget.

# Bind-mount host paths for shared media storage.
# Both arr and Jellyfin should share the same host path so hardlinks work.
jellyfin_media_bind_mount_host_path = "/mnt/media"

# Set true and supply bind mounts to enable the media automation stack.
enable_arr_stack    = false
enable_qbittorrent  = false
# arr_media_bind_mount_host_path                  = "/mnt/media"
# arr_downloads_bind_mount_host_path              = "/mnt/downloads"
# qbittorrent_downloads_bind_mount_host_path      = "/mnt/downloads"  # same as arr_downloads

# Tailscale — enable core device management after lab-core joins the tailnet.
enable_tailscale_management            = false
enable_tailscale_core_device_management = false
tailscale_tailnet                      = "-"

# Cloudflare DNS — enable after adre.me is on Cloudflare.
enable_cloudflare_dns = false
cloudflare_zone_name  = "adre.me"
cloudflare_zone_id    = ""
# Set CLOUDFLARE_API_TOKEN or TF_VAR_cloudflare_api_token in the environment.
