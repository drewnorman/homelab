proxmox_node_name = "norman"

network_bridge  = "vmbr0"
network_gateway = "192.168.1.1"
network_cidr    = 24

search_domain = "lab.adre.me"
dns_servers   = ["192.168.1.1", "1.1.1.1"]

lxc_storage          = "local-lvm"
vm_storage           = "local-lvm"
lxc_template_file_id = "local:vztmpl/debian-12-standard_12.12-1_amd64.tar.zst"

# Docker VM provisioning is disabled until vm_template_id points at a
# cloud-init-capable VM template.
enable_docker_host = false
enable_nix_host    = true
# vm_template_id   = 9000

service_ips = {
  adguard_lxc         = "192.168.1.210"
  edge_lxc            = "192.168.1.211"
  homepage_lxc        = "192.168.1.212"
  authelia_lxc        = "192.168.1.213"
  lldap_lxc           = "192.168.1.214"
  jellyfin_lxc        = "192.168.1.230"
  arr_lxc             = "192.168.1.232"
  qbittorrent_vpn_lxc = "192.168.1.233"
  nix_host_lxc        = "192.168.1.240"
}

nix_config_repo_url   = "https://github.com/drewnorman/nix-config"
nix_config_flake_host = "nix"

manage_nix_lxc_template     = true
nix_lxc_template_datastore_id = "local"
nix_lxc_template_file_name  = "nixos-lxc-lab-nix.tar.xz"
nix_lxc_template_url        = "https://hydra.nixos.org/job/nixos/release-25.11/nixos.proxmoxLXC.x86_64-linux/latest/download-by-type/file/system-tarball"
nix_lxc_template_file_id = "local:vztmpl/nixos-lxc-lab-nix.tar.xz"

nix_host_lxc_resources = {
  cores        = 4
  memory_mb    = 4096
  swap_mb      = 1024
  disk_size_gb = 32
}

jellyfin_lxc_disk_size_gb = 16

# Example: mount a host path backed by an external SSD into Jellyfin at /mnt/media.
jellyfin_media_bind_mount_host_path = "/mnt/media"

# For hardlinks to work, downloads and media must be on the same host filesystem.
enable_arr_stack = false
enable_qbittorrent_vpn = false
# arr_media_bind_mount_host_path = "/mnt/media"

# Optional Tailscale API automation. Enable edge device management only after
# lab-edge has joined the tailnet once.
enable_tailscale_management = false
enable_tailscale_edge_device_management = false
tailscale_tailnet = "-"

# Enable after adre.me is using Cloudflare DNS and an API token is available.
enable_cloudflare_dns = false
cloudflare_zone_name  = "adre.me"
cloudflare_zone_id    = ""
# Set credentials through CLOUDFLARE_API_TOKEN or TF_VAR_cloudflare_api_token.

cloudflare_dns_records = [
  {
    key  = "caa-letsencrypt"
    name = ""
    type = "CAA"
    data = {
      flags = 0
      tag   = "issue"
      value = "letsencrypt.org"
    }
    ttl     = 3600
    comment = "Allow Let's Encrypt certificates for adre.me"
    proxied = false
  },
  {
    key  = "caa-lab-letsencrypt"
    name = "lab"
    type = "CAA"
    data = {
      flags = 0
      tag   = "issue"
      value = "letsencrypt.org"
    }
    ttl     = 3600
    comment = "Allow Let's Encrypt certificates for lab.adre.me"
    proxied = false
  },
  {
    key  = "caa-lab-letsencrypt-wildcard"
    name = "lab"
    type = "CAA"
    data = {
      flags = 0
      tag   = "issuewild"
      value = "letsencrypt.org"
    }
    ttl     = 3600
    comment = "Allow Let's Encrypt wildcard certificates for lab.adre.me"
    proxied = false
  }
]
