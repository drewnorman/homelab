proxmox_node_name = "norman"
proxmox_ssh_host  = "192.168.1.200"

network_bridge  = "vmbr0"
network_gateway = "192.168.1.1"
network_cidr    = 24

search_domain = "lab.adre.me"
dns_servers   = ["192.168.1.1", "1.1.1.1"]

# Consolidated NixOS VM. Build or import a NixOS cloud-init template first.
enable_core_vm         = true
core_vm_template_vm_id = 9000
core_vm_id             = 120
core_vm_ip             = "192.168.1.210"
core_vm_storage        = "local-lvm"
core_vm_disk_gb         = 96
core_vm_media_disk_path = "/dev/disk/by-uuid/06d2efe6-c0b5-411c-8747-3a4ff0242979"
core_vm_cores           = 6
core_vm_memory_mb       = 12288

# Tailscale — enable core device management after lab-core joins the tailnet.
enable_tailscale_management            = false
enable_tailscale_core_device_management = false
tailscale_tailnet                      = "-"

# Cloudflare DNS — enable after adre.me is on Cloudflare.
enable_cloudflare_dns = false
cloudflare_zone_name  = "adre.me"
cloudflare_zone_id    = ""
# Set CLOUDFLARE_API_TOKEN or TF_VAR_cloudflare_api_token in the environment.
