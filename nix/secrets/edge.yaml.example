# Encrypt this file with: sops secrets/edge.yaml
#
# cloudflare-dns-api-token must be a systemd EnvironmentFile line so the acme
# service can read it as an environment variable.
cloudflare-dns-api-token: "CLOUDFLARE_DNS_API_TOKEN=replace-with-cloudflare-api-token"
tailscale-auth-key: "tskey-auth-replace-me"
slack-webhook-url: "https://hooks.slack.com/services/replace/me"
