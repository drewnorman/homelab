# Encrypt this file with: sops secrets/authelia.yaml
# Generate secrets with: openssl rand -hex 32
authelia-jwt-secret: "replace-with-random-32-byte-hex"
authelia-session-secret: "replace-with-random-32-byte-hex"
authelia-storage-encryption-key: "replace-with-random-32-byte-hex"
authelia-lldap-password: "replace-with-lldap-admin-password"
tailscale-auth-key: "tskey-auth-replace-me"
