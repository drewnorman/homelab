# Encrypt this file with: sops secrets/qbittorrent.yaml
# protonvpn-wireguard-config is the full WireGuard config file contents
# (not base64 encoded — sops handles the encryption).
protonvpn-wireguard-config: |
  [Interface]
  PrivateKey = replace-me
  Address = 10.2.0.2/32
  DNS = 10.2.0.1

  [Peer]
  PublicKey = replace-me
  AllowedIPs = 0.0.0.0/0
  Endpoint = replace-me:51820
