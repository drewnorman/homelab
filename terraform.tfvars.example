proxmox_node_name = "norman"

network_bridge  = "vmbr0"
network_gateway = "172.16.0.1"
network_cidr    = 24

search_domain = "lab.adre.me"
dns_servers   = ["172.16.0.1", "1.1.1.1"]

lxc_storage          = "local-lvm"
vm_storage           = "local-lvm"
lxc_template_file_id = "local:vztmpl/debian-12-standard_12.12-1_amd64.tar.zst"

# The Proxmox host does not currently have a VM template, so Docker VM
# provisioning is disabled until vm_template_id points at one.
enable_docker_host = false
# vm_template_id   = 9000

service_ips = {
  adguard_lxc    = "172.16.0.210"
  edge_lxc       = "172.16.0.211"
  docker_host_vm = "172.16.0.220"
  jellyfin_lxc   = "172.16.0.230"
}

# Example: mount a host path backed by an external SSD into Jellyfin at /srv/media.
# jellyfin_media_bind_mount_host_path = "/mnt/media"

# Enable after adre.me is using Porkbun DNS and API access is enabled for the domain.
enable_porkbun_dns = false
porkbun_domain     = "adre.me"
# Set credentials through TF_VAR_porkbun_api_key and TF_VAR_porkbun_secret_api_key.

porkbun_dns_records = [
  {
    key     = "caa-letsencrypt"
    name    = ""
    type    = "CAA"
    content = "0 issue \"letsencrypt.org\""
    ttl     = 600
    notes   = "Allow Let's Encrypt certificates for adre.me"
  }
]
